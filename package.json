{
  "name": "exam-forge-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend-only AI study exam generator deployable on GitHub Pages.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n web,links -c green,yellow \"npm run dev:web\" \"node scripts/show-dev-links.js\"",
    "dev:web": "npm run start --workspace studyforge-web -- --host 0.0.0.0",
    "build": "npm run build --workspace studyforge-web",
    "build:gh-pages": "npm run build --workspace studyforge-web -- --base-href /ExamForgeAI/",
    "start:web": "npm run start --workspace studyforge-web",
    "test": "tsc -p apps/web/tsconfig.spec.json --noEmit",
    "test:browser": "npm run test --workspace studyforge-web -- --watch=false --browsers=ChromeHeadless"
  },
  "keywords": [
    "studyforge",
    "exam",
    "angular",
    "github-pages",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
